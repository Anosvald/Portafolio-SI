---
import GitHub from "./Icons/GitHub.astro"
import NextJS from "./Icons/NextJS.astro"
import Tailwind from "./Icons/Tailwind.astro"
import Estilooos from "./Icons/Estilooos.astro"
import Link from "./Icons/Link.astro"
import LinkButton from "./LinkButton.astro"
import Java from "./Icons/Java.astro"
import Htmmml from "./Icons/Htmmml.astro" 
import Jjjsss from "./Icons/Jjjsss.astro" 
import Cc from "./Icons/Cc.astro" 
// --- NUEVOS ÍCONOS DE SEGURIDAD ---
import Security from "./Icons/Security.astro"
import Security1 from "./Icons/Security1.astro"
import Security2 from "./Icons/Security2.astro"

// --- RECIBIMOS EL NÚMERO DE PARCIAL ---
const { parcial = 1 } = Astro.props;

const TAGS = {
  JAVA: {
    name: "Java",
    class: "bg-black text-white",
    icon: Java,
  },
  HTMMML: {
    name: "HTML",
    class: "bg-[#003159] text-white",
    icon: Htmmml,
  },
  Estilooos: {
    name: "CSS",
    class: "bg-black text-white",
    icon: Estilooos,
  },
  Jjjsss: {
    name: "js",
    class: "bg-black text-white",
    icon: Jjjsss,
  },
  Cc: {
    name: "Lenguaje C",
    class: "bg-[#003159] text-white",
    icon: Cc,
  },
  // --- NUEVAS ETIQUETAS PARA CIBERSEGURIDAD ---
  PENTESTING: {
    name: "Pentesting",
    class: "bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300",
    icon: Security, 
  },
  KALI: {
    name: "Kali Linux",
    class: "bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300",
    icon: Security1, 
  },
  SEGURIDAD: {
    name: "Seguridad / Análisis",
    class: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300",
    icon: Security2, 
  }
}

const PROJECTS = [
  {
    "title": "Proyecto 01: Pentesting - Máquina SNAKEOIL",
    "description": "Auditoría de seguridad ofensiva completa (De Caja Negra a Caja Blanca). Exploración de red, explotación de inyección de comandos vía SSRF, análisis de código estático (SAST) y escalada de privilegios a usuario root.",
    "link": "/Proyectos/Proyecto1",
    "github": "", 
    "image": "/projects/Proyecto1.png", 
    "tags": [TAGS.PENTESTING, TAGS.KALI],
    "parcial": 1 // <-- ASIGNADO AL PARCIAL 1
  },
  {
    "title": "Proyecto 02: Investigación Comparativa de Plataformas HRM",
    "description": "Análisis comparativo de ocho plataformas líderes en la gestión del riesgo humano (HRM) en ciberseguridad, evaluando dimensiones técnicas, métricas, metodologías y controles éticos.",
    "link": "/Proyectos/Proyecto2",
    "github": "", 
    "image": "/projects/Proyecto2.png", 
    "tags": [TAGS.SEGURIDAD],
    "parcial": 2 // <-- ASIGNADO AL PARCIAL 2
  },
  {
    "title": "Proyecto 03: Phishing Quiz Interactivo",
    "description": "Simulación interactiva de 10 escenarios de ingeniería social con evaluación en tiempo real y Ranking Global potenciado por Firebase.",
    "link": "/Proyectos/Proyecto3",
    "github": "", 
    "image": "/projects/Proyecto3.png", 
    "tags": [TAGS.SEGURIDAD],
    "parcial": 2 // <-- ASIGNADO AL PARCIAL 2
  },
  
  /*
  {
    "title": "Plataforma Web para Exploración de Artistas Globales",
    "description": "Desarrollo de una plataforma interactiva para visualizar artistas de renombre mundial. Permite a los usuarios explorar información detallada de diversos cantantes y bandas. Construida desde cero con html y CSS.",
    "link": "https://anosvald.github.io/Music.github.io/",
    "github": "https://github.com/Anosvald/Music.github.io.git",
    "image": "/projects/Artistas.png",
    "tags": [TAGS.Estilooos, TAGS.HTMMML]
  },
  ... (RESTO DE TUS PROYECTOS COMENTADOS) ...
  */
]

// --- FILTRAMOS LOS PROYECTOS POR PARCIAL ---
const FILTERED_PROJECTS = PROJECTS.filter(project => project.parcial === parcial);
---

<div class="flex flex-col gap-y-16">
  {
    FILTERED_PROJECTS.map(({ image, title, description, tags, link, github }) => (
    <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
  <div class="w-full md:w-1/2">
    <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
      <img class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105" loading="lazy" src={image} />
    </div>
  </div>

  <div class="w-full md:w-1/2 md:max-w-lg">
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      {title}
    </h3>
    <div class="flex flex-wrap mt-2">
      <ul class="flex flex-row mb-2 gap-x-2">
          {tags.map((tag) => (
            <li>
              <span
                class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
              >
                <tag.icon class="size-4" />
                {tag.name}
              </span>
            </li>
          ))}
        </ul>

      <div class="mt-2 text-gray-700 dark:text-gray-400">{description}</div>
      <footer class="flex items-end justify-start mt-4 gap-x-4">
          
          {github && (
            <LinkButton href={github}>
              <GitHub class="size-6" />
              Code
            </LinkButton>
          )}
          
          {link && (
            <a 
              href={link}
              class="bg-white/5 border dark:border-white/10 border-gray-300 rounded-full inline-flex justify-center items-center gap-x-2 py-1 px-2 md:py-2 md:px-4 text-xs md:text-base transition hover:scale-110 hover:bg-white/10 text-gray-800 dark:text-white"
            >
              <Link class="size-4" />
              Preview
            </a>
          )}

        </footer>
    </div>
  </div>
</article>
    ))
  }
</div>