---
import Layout from "../../layouts/Layout.astro"
import Shield  from "../../components/Icons/Shield.astro"
import Block   from "../../components/Icons/Block.astro"
import Sms     from "../../components/Icons/Sms.astro"
import Camera  from "../../components/Icons/Camera.astro"
import Wifi    from "../../components/Icons/Wifi.astro"
import Accept  from "../../components/Icons/Accept.astro"
import XIcon   from "../../components/Icons/X.astro"
import Pishing from "../../components/Icons/Pishing.astro"
import Mail    from "../../components/Icons/Mail.astro"

const INFO_TAREA = {
  titulo: "Phishing Quiz: Test de Ingeniería Social",
  descripcion: "Simulación interactiva de 10 escenarios de phishing para evaluar la capacidad de detección de amenazas en entornos digitales.",
}

const ESCENARIOS = Array.from({ length: 10 }, (_, i) => ({
  id: i + 1,
  label: `Escenario ${String(i + 1).padStart(2, '0')}`
}));
---

<Layout title={`Portafolio - ${INFO_TAREA.titulo}`} description={INFO_TAREA.descripcion}>
<style>
  /* ── Hide global header/nav on this page only ── */
  :global(header), :global(nav) { display: none !important; }

  /* ══════════════════════════
     SIDEBAR
  ══════════════════════════ */
  #roadmap-sidebar {
    width: 236px;
    flex-shrink: 0;
    position: sticky;
    top: 1.5rem;
    height: calc(100vh - 3rem);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #334155 transparent;
  }

  /* Progress bar */
  .prog-track {
    height: 5px;
    background: #e2e8f0;
    border-radius: 9999px;
    overflow: hidden;
  }
  .dark .prog-track { background: #1e293b; }
  .prog-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);
    border-radius: 9999px;
    transition: width 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 0 8px rgba(99,102,241,0.35);
  }

  /* Sidebar items */
  .sbi {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.45rem 0.5rem 0.45rem 0;
    border-radius: 0.5rem;
    transition: all 0.22s ease;
    opacity: 0.4;
    cursor: default;
    user-select: none;
  }
  .sbi-num {
    width: 2rem;
    height: 2rem;
    border-radius: 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 800;
    font-family: 'Courier New', monospace;
    flex-shrink: 0;
    border: 1.5px solid;
    transition: all 0.22s ease;
    /* pending */
    background: transparent;
    border-color: #cbd5e1;
    color: #94a3b8;
  }
  .dark .sbi-num { border-color: #334155; color: #475569; }

  .sbi-label {
    font-size: 0.8rem;
    font-weight: 500;
    transition: color 0.2s, font-weight 0.2s;
    color: #64748b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }
  .sbi-badge {
    display: none;
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.1rem 0.3rem;
    border-radius: 0.2rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* active */
  .sbi.active { opacity: 1; background: rgba(59,130,246,0.06); }
  .dark .sbi.active { background: rgba(59,130,246,0.1); }
  .sbi.active .sbi-num {
    background: #3b82f6;
    border-color: #3b82f6;
    color: #fff;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.22);
  }
  .sbi.active .sbi-label { color: #3b82f6; font-weight: 700; }

  /* correct */
  .sbi.done-ok { opacity: 1; }
  .sbi.done-ok .sbi-num { background: #10b981; border-color: #10b981; color: #fff; box-shadow: 0 0 0 3px rgba(16,185,129,0.15); }
  .sbi.done-ok .sbi-label { color: #10b981; }
  .sbi.done-ok .sbi-badge { display: inline-block; background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.25); }

  /* incorrect */
  .sbi.done-fail { opacity: 1; }
  .sbi.done-fail .sbi-num { background: #ef4444; border-color: #ef4444; color: #fff; box-shadow: 0 0 0 3px rgba(239,68,68,0.15); }
  .sbi.done-fail .sbi-label { color: #ef4444; }
  .sbi.done-fail .sbi-badge { display: inline-block; background: rgba(239,68,68,0.08); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }

  /* ══════════════════════════
     SCENARIO HEADER (above each scenario card)
  ══════════════════════════ */
  .scene-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.625rem;
    padding: 0 0.25rem;
  }
  .scene-counter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .scene-counter-num {
    font-size: 0.68rem;
    font-weight: 800;
    font-family: 'Courier New', monospace;
    letter-spacing: 0.06em;
    color: #3b82f6;
    background: rgba(59,130,246,0.08);
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 0.3rem;
    padding: 0.18rem 0.5rem;
  }
  .dark .scene-counter-num { background: rgba(59,130,246,0.12); border-color: rgba(59,130,246,0.25); }
  .scene-steps {
    display: flex;
    gap: 3px;
  }
  .scene-step-dot {
    width: 18px;
    height: 4px;
    border-radius: 2px;
    background: #e2e8f0;
    transition: background 0.3s;
  }
  .dark .scene-step-dot { background: #1e293b; }
  .scene-step-dot.done { background: #10b981; }
  .scene-step-dot.fail { background: #ef4444; }
  .scene-step-dot.cur  { background: #3b82f6; }

  .scene-type-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    background: #0f172a;
    color: #475569;
    border: 1px solid #1e293b;
  }

  /* ══════════════════════════
     SCENARIO / SCREEN SHOW/HIDE
  ══════════════════════════ */
  .scenario-container { display: none; }
  .scenario-container.active { display: block; animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ══════════════════════════
     DECISION PANEL
  ══════════════════════════ */
  #decision-panel { display: none; }
  #decision-panel.visible { display: block; animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1); }

  .dp-card {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 1rem;
    padding: 1.125rem 1.25rem;
    margin-top: 0.875rem;
  }

  .dp-prompt {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #94a3b8;
    text-align: center;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .dp-prompt::before, .dp-prompt::after { content:''; flex:1; height:1px; background:#1e293b; }

  .dp-btns { display: flex; gap: 0.75rem; }

  .dp-btn {
    flex: 1;
    padding: 0.875rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.9rem;
    font-weight: 800;
    border: 2px solid;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }
  .dp-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: currentColor;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .dp-btn:hover { transform: translateY(-2px); }
  .dp-btn:active { transform: scale(0.97) translateY(0); }

  .dp-phishing {
    background: rgba(239,68,68,0.05);
    border-color: rgba(239,68,68,0.3);
    color: #dc2626;
  }
  .dark .dp-phishing { background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.3); color: #f87171; }
  .dp-phishing:hover { background: rgba(239,68,68,0.12); border-color: #ef4444; box-shadow: 0 4px 20px rgba(239,68,68,0.2); }

  .dp-legitimo {
    background: rgba(16,185,129,0.05);
    border-color: rgba(16,185,129,0.25);
    color: #059669;
  }
  .dark .dp-legitimo { background: rgba(16,185,129,0.08); border-color: rgba(16,185,129,0.25); color: #34d399; }
  .dp-legitimo:hover { background: rgba(16,185,129,0.12); border-color: #10b981; box-shadow: 0 4px 20px rgba(16,185,129,0.2); }

  .dp-shortcut {
    font-size: 0.6rem;
    font-family: 'Courier New', monospace;
    font-weight: 700;
    opacity: 0.5;
    background: currentColor;
    color: inherit;
    padding: 0.1rem 0.3rem;
    border-radius: 0.2rem;
    border: 1px solid currentColor;
  }

  /* ══════════════════════════
     FEEDBACK MODAL
  ══════════════════════════ */
  #feedback-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  #feedback-modal.visible { display: flex; animation: backdropIn 0.2s ease; }
  @keyframes backdropIn { from { opacity:0; } to { opacity:1; } }

  #feedback-card {
    max-height: 88vh;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #334155 transparent;
    animation: cardPop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes cardPop {
    from { opacity:0; transform: scale(0.9) translateY(20px); }
    to   { opacity:1; transform: scale(1) translateY(0); }
  }

  /* Verdict strip */
  .fb-verdict-ok   { background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(16,185,129,0.03)); border-bottom-color: rgba(16,185,129,0.18) !important; }
  .fb-verdict-fail { background: linear-gradient(135deg, rgba(239,68,68,0.1), rgba(239,68,68,0.03)); border-bottom-color: rgba(239,68,68,0.18) !important; }

  /* Indicator cards */
  .fb-ind {
    border-left: 3px solid;
    border-radius: 0.5rem;
    padding: 0.8rem 0.95rem;
    margin-bottom: 0.5rem;
    transition: transform 0.15s;
  }
  .fb-ind:hover { transform: translateX(2px); }
  .fb-ind.danger  { background: rgba(239,68,68,0.04);  border-color: #ef4444; }
  .dark .fb-ind.danger  { background: rgba(239,68,68,0.07); }
  .fb-ind.success { background: rgba(16,185,129,0.04); border-color: #10b981; }
  .dark .fb-ind.success { background: rgba(16,185,129,0.07); }

  .fb-ind-title {
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
    line-height: 1.4;
  }
  .fb-ind.danger  .fb-ind-title { color: #dc2626; }
  .dark .fb-ind.danger  .fb-ind-title { color: #f87171; }
  .fb-ind.success .fb-ind-title { color: #059669; }
  .dark .fb-ind.success .fb-ind-title { color: #34d399; }

  .fb-ind-body { font-size: 0.8rem; line-height: 1.65; color: #475569; }
  .dark .fb-ind-body { color: #94a3b8; }
  .fb-ind-body code {
    font-family: 'Fira Code', 'Courier New', monospace;
    font-size: 0.74rem;
    background: rgba(59,130,246,0.07);
    color: #3b82f6;
    padding: 0.07rem 0.3rem;
    border-radius: 0.22rem;
    border: 1px solid rgba(59,130,246,0.15);
  }
  .dark .fb-ind-body code { background: rgba(99,102,241,0.1); color: #818cf8; border-color: rgba(99,102,241,0.2); }
  .fb-ind-body strong { color: #1e293b; font-weight: 600; }
  .dark .fb-ind-body strong { color: #e2e8f0; }
  .fb-ind-body em { color: #f59e0b; font-style: normal; font-weight: 600; }

  .fb-lesson {
    background: rgba(245,158,11,0.055);
    border: 1px solid rgba(245,158,11,0.18);
    border-left: 3px solid #f59e0b;
    border-radius: 0.5rem;
    padding: 0.85rem 1rem;
    font-size: 0.8rem;
    line-height: 1.65;
    color: #fcd34d;
    margin-bottom: 1rem;
  }
  .fb-lesson strong { color: #fbbf24; font-weight: 700; }

  .fb-sec-title {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #94a3b8;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .fb-sec-title::after { content:''; flex:1; height:1px; background:#1e293b; }

  /* ══════════════════════════
     RESULTS — animated score ring
  ══════════════════════════ */
  .score-ring-wrap {
    position: relative;
    width: 11rem;
    height: 11rem;
    margin: 0 auto 2rem;
  }
  .score-ring-svg { position: absolute; inset: 0; transform: rotate(-90deg); }
  .score-ring-bg { fill: none; stroke: #1e293b; stroke-width: 8; }
  .score-ring-arc {
    fill: none;
    stroke: url(#scoreGrad);
    stroke-width: 8;
    stroke-linecap: round;
    stroke-dasharray: 314;
    stroke-dashoffset: 314;
    transition: stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .score-ring-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* Stat cards */
  .stat-card {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .stat-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.35); transform: translateY(-1px); }
  .stat-label { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #475569; margin-bottom: 0.25rem; }
  .stat-value { font-size: 1.05rem; font-weight: 800; color: #e2e8f0; }

  /* Score color thresholds */
  .score-s { color: #10b981; }  /* 9-10 */
  .score-a { color: #3b82f6; }  /* 7-8  */
  .score-b { color: #f59e0b; }  /* 5-6  */
  .score-c { color: #ef4444; }  /* 0-4  */

  /* ══════════════════════════════════════════
     RANKING GLOBAL — DISEÑO MEJORADO
  ══════════════════════════════════════════ */

  /* Divider */
  .rank-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .rank-divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, #1e293b 40%, #1e293b 60%, transparent);
  }
  .rank-divider-label {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #475569;
    white-space: nowrap;
    padding: 0.3rem 0.75rem;
    background: #0a0e18;
    border: 1px solid #1e293b;
    border-radius: 9999px;
  }

  /* Loading */
  .ranking-spinner {
    width: 2rem;
    height: 2rem;
    border: 2px solid #1e293b;
    border-top-color: #3b82f6;
    border-right-color: #6366f1;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    margin: 1.5rem auto 0.75rem;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Table wrapper */
  #ranking-table-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 0.875rem !important;
    border: 1px solid #1a2236 !important;
  }
  #ranking-table-wrap::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 5%, #3b82f6 40%, #6366f1 60%, transparent 95%);
    opacity: 0.7;
    z-index: 2;
    pointer-events: none;
  }

  /* Table cap — header bar above thead */
  .ranking-cap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.875rem;
    background: #050810;
    border-bottom: 1px solid #0f172a;
  }
  .ranking-cap-title {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #334155;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .ranking-cap-title::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background: #3b82f6;
    border-radius: 50%;
    box-shadow: 0 0 6px #3b82f6;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px #3b82f6; }
    50% { opacity: 0.5; box-shadow: 0 0 2px #3b82f6; }
  }
  .ranking-cap-count {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #1e293b;
    font-family: 'Courier New', monospace;
  }

  /* Table */
  .ranking-table { width: 100%; border-collapse: collapse; }
  .ranking-table thead tr {
    background: linear-gradient(to bottom, #070b13, #050810);
  }
  .ranking-table th {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1e293b;
    padding: 0.6rem 0.875rem;
    text-align: left;
    border-bottom: 1px solid #0f172a;
  }
  .ranking-table td {
    padding: 0.7rem 0.875rem;
    font-size: 0.81rem;
    color: #475569;
    border-bottom: 1px solid rgba(15, 23, 42, 0.8);
    transition: background 0.18s ease, color 0.18s ease;
  }
  .ranking-table tbody tr:hover td { background: rgba(59,130,246,0.035); }
  .ranking-table tbody tr:last-child td { border-bottom: none; }

  /* Current user row */
  .ranking-row-me td {
    background: rgba(59,130,246,0.06) !important;
    color: #94a3b8 !important;
  }
  .ranking-row-me:hover td { background: rgba(59,130,246,0.09) !important; }
  .ranking-row-me td:first-child {
    border-left: 2px solid #3b82f6;
    padding-left: calc(0.875rem - 2px);
  }

  /* Position badge */
  .ranking-pos {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    font-family: 'Courier New', monospace;
    font-weight: 800;
    font-size: 0.6rem;
    color: #334155;
    background: #0a0e18;
    border: 1px solid #1e293b;
    border-radius: 0.4rem;
  }
  .ranking-pos.gold {
    font-size: 1rem;
    background: rgba(245,158,11,0.07);
    border-color: rgba(245,158,11,0.2);
    box-shadow: 0 0 10px rgba(245,158,11,0.1);
  }
  .ranking-pos.silver {
    font-size: 1rem;
    background: rgba(148,163,184,0.05);
    border-color: rgba(148,163,184,0.15);
  }
  .ranking-pos.bronze {
    font-size: 1rem;
    background: rgba(180,83,9,0.06);
    border-color: rgba(180,83,9,0.18);
  }

  /* Score chips */
  .ranking-score {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.76rem;
    font-family: 'Courier New', monospace;
    padding: 0.18rem 0.55rem;
    border-radius: 0.375rem;
    min-width: 2.75rem;
    letter-spacing: 0.02em;
  }
  .score-col-s {
    color: #10b981;
    background: rgba(16,185,129,0.08);
    border: 1px solid rgba(16,185,129,0.2);
    box-shadow: 0 0 8px rgba(16,185,129,0.08);
  }
  .score-col-a {
    color: #3b82f6;
    background: rgba(59,130,246,0.08);
    border: 1px solid rgba(59,130,246,0.2);
    box-shadow: 0 0 8px rgba(59,130,246,0.08);
  }
  .score-col-b {
    color: #f59e0b;
    background: rgba(245,158,11,0.08);
    border: 1px solid rgba(245,158,11,0.2);
    box-shadow: 0 0 8px rgba(245,158,11,0.08);
  }
  .score-col-c {
    color: #ef4444;
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.18);
    box-shadow: 0 0 8px rgba(239,68,68,0.06);
  }

  /* Analysis grid */
  .analysis-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.625rem;
  }
  .analysis-card {
    background: #080c14;
    border: 1px solid #1a2236;
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .analysis-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.4);
  }
