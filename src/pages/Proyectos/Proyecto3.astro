      indicators: [
        { c:"danger", t:"Dominio del remitente: netflix-billing-update.com no es Netflix", b:`El correo viene de <code>support@netflix-billing-update.com</code>. Netflix usa exclusivamente <code>@account.netflix.com</code>, <code>@mailer.netflix.com</code> o <code>@netflix.com</code>. Aunque <code>netflix-billing-update.com</code> contiene la palabra "netflix", <strong>ese dominio no pertenece a Netflix</strong>: cualquier persona puede registrar un dominio con "netflix" en el nombre. El dominio oficial siempre termina en <code>netflix.com</code>, no en variaciones con guiones.` },
        { c:"danger", t:"El nombre personalizado no prueba que el correo sea de Netflix", b:`Los atacantes obtienen listas de nombre + correo + servicio de <strong>filtraciones masivas de bases de datos</strong>. Que conozcan tu nombre <em>no</em> significa que el correo sea de Netflix.` },
        { c:"danger", t:"'Para volver a ver Netflix' crea urgencia implícita de acceso perdido", b:`Esta frase implica que <em>ya perdiste el acceso</em>, creando urgencia sin amenaza explícita. Es una técnica sofisticada: no te amenaza directamente pero te hace asumir que tienes un problema urgente que resolver ahora.` },
        { c:"danger", t:"'ACTUALIZAR PAGO' lleva a una página de captura de tarjeta", b:`El enlace apunta a <code>netflix-billing-update.com/login</code>, una página visualmente idéntica a Netflix. El atacante captura en tiempo real número de tarjeta, fecha de vencimiento y CVV. El dominio parece legítimo a simple vista porque contiene la palabra "netflix", pero <strong>no es netflix.com</strong>.` },
        { c:"danger", t:"El pie de página oficial copiado no convierte un dominio falso en legítimo", b:`El texto "© 2026 Netflix, Inc. 100 Winchester Circle..." fue copiado de correos reales de Netflix. <strong>Cualquier atacante puede hacer esto</strong>. Un pie de página no tiene ningún peso técnico para autenticar el dominio del remitente.` }
      ],
      lesson: `<strong>💡 Regla de oro:</strong> Ante cualquier correo de "problema de pago", cierra el correo y entra <strong>manualmente</strong> a <code>netflix.com</code> desde tu navegador para verificar el estado real de tu cuenta.`
    },
    9: {
      type: "✅ Encuesta de Satisfacción Legítima de MercadoLibre",
      indicators: [
        { c:"success", t:"Dominio del remitente oficial: mercadolibre.com verificado", b:`El correo viene de <code>noreply@no-responder.mercadolibre.com</code>. El dominio raíz es <strong>mercadolibre.com</strong>, verificable en registros WHOIS. El subdominio <code>no-responder</code> es el que Mercado Libre usa estándarmente para comunicaciones masivas de marketing.` },
        { c:"success", t:"El enlace de acción permanece dentro de mercadolibre.com", b:`El botón lleva a <code>formularios.mercadolibre.com/encuestas/...</code>. El dominio raíz es <strong>mercadolibre.com</strong>. No hay redirecciones a terceros, no hay dominios sospechosos.` },
        { c:"success", t:"No solicita contraseña, datos bancarios ni información sensible", b:`La encuesta pide exclusivamente la <strong>opinión del usuario</strong> sobre Meli+. No solicita credenciales, datos de tarjeta, CVV, CURP ni RFC. Las encuestas de satisfacción legítimas solo necesitan respuestas de valoración.` },
        { c:"success", t:"El enlace 'Darse de baja' es obligatorio y su presencia es indicador positivo", b:`La LFPDPPP y regulaciones anti-spam internacionales <strong>exigen</strong> este enlace en correos comerciales. Los atacantes raramente lo incluyen porque no les interesa el cumplimiento legal. Su presencia es un indicador positivo de legitimidad.` },
        { c:"success", t:"Tono cordial, no urgente y completamente transparente", b:`El mensaje usa frases como "solo te tomará unos minutos" y "¡Muchas gracias!". No hay amenazas, no hay cargos, no hay cuentas en riesgo, no hay plazos de tiempo. El tono es exactamente lo opuesto al phishing.` }
      ],
      lesson: `<strong>💡 Lección Clave:</strong> No todo correo con un enlace es phishing. Los indicadores positivos incluyen: dominio oficial del remitente, enlaces dentro del mismo dominio, sin solicitud de datos sensibles, tono no amenazante y opción de darse de baja. Aprender a reconocer lo legítimo es igual de importante que detectar lo peligroso.`
    },
    10: {
      type: "Evil Twin / Portal Cautivo Malicioso — Ataque de Wi-Fi",
      indicators: [
        { c:"danger", t:"Las redes Wi-Fi NUNCA necesitan la contraseña de tu correo", b:`Para conectarte a Wi-Fi, tu dispositivo se autentica con el punto de acceso mediante el protocolo 802.11. Este proceso es <strong>completamente independiente de tu cuenta de correo</strong>. Tu contraseña de Gmail, Outlook o Yahoo es irrelevante para establecer una conexión. Una red que la solicita está capturando credenciales.` },
        { c:"danger", t:"Evil Twin: el punto de acceso falso imita el SSID real del aeropuerto", b:`El atacante crea un punto de acceso con el <strong>mismo nombre (SSID)</strong> que la red legítima. Tu dispositivo puede unirse automáticamente al punto falso. El portal cautivo malicioso captura tus credenciales <em>antes</em> de darte acceso real a internet.` },
        { c:"danger", t:"Los portales legítimos nunca piden contraseñas de servicios externos", b:`Los portales cautivos legítimos pueden pedir aceptar términos o ingresar tu correo para recibir un <em>código de un solo uso</em>. Lo que <strong>absolutamente nunca piden</strong>: la contraseña de tu correo ni credenciales de ningún servicio. Esa información no tiene ninguna función técnica para conectarte a Wi-Fi.` },
        { c:"danger", t:"La etiqueta en rojo 'Contraseña de tu correo' revela la intención", b:`El campo en <strong>color rojo</strong> imita el diseño de campo obligatorio crítico. Los portales Wi-Fi legítimos usan formularios simples y neutrales; no marcan campos de contraseña de servicios externos como urgentes.` },
        { c:"danger", t:"Consecuencia: control total de tu vida digital en segundos", b:`Si ingresas tu contraseña, el atacante obtiene <strong>control total de tu cuenta</strong>. Desde ahí puede: resetear contraseñas de TODOS tus servicios vinculados (bancos, redes sociales, tiendas), leer información confidencial, y suplantar tu identidad. El daño es inmediato y masivo.` }
      ],
      lesson: `<strong>💡 Regla de oro:</strong> En Wi-Fi pública, usa siempre una VPN confiable y verifica el SSID exacto con personal del establecimiento. <strong>Si un portal cautivo pide tu contraseña de correo, cierra inmediatamente.</strong> Usa los datos móviles de tu celular como hotspot siempre que sea posible.`
    }
  };

  /* ══════════════════════════
     STATE
  ══════════════════════════ */
  let step = 0;
  let score = 0;
  let phishingOk = 0;
  let legitOk = 0;
  let startTime = 0;
  const times = [];
  let userName = "";
  let userEmail = "";
  const results = {}; // step -> {ok, correct}

  /* ══════════════════════════
     ELEMENTS
  ══════════════════════════ */
  const introScreen   = document.getElementById("intro-screen");
  const decPanel      = document.getElementById("decision-panel");
  const fbModal       = document.getElementById("feedback-modal");
  const resultsScreen = document.getElementById("results-screen");
  const progFill      = document.getElementById("progress-fill");
  const scoreCounter  = document.getElementById("score-counter");
  const sidebarScore  = document.getElementById("sidebar-score");

  /* ══════════════════════════
     START
  ══════════════════════════ */
  document.getElementById("btn-start-quiz").addEventListener("click", () => {
    const name  = document.getElementById("user-name").value.trim();
    const email = document.getElementById("user-email").value.trim();
    const err   = document.getElementById("form-error");
    if (!name || !email) { err.classList.remove("hidden"); return; }
    err.classList.add("hidden");
    userName = name; userEmail = email;
    introScreen.classList.remove("active");
    showScene(1);
  });

  /* ══════════════════════════
     SHOW SCENE
  ══════════════════════════ */
  function showScene(n) {
    step = n;
    document.querySelectorAll(".scenario-container").forEach(el => el.classList.remove("active"));
    const sc = document.getElementById(`scenario-${n}`);
    if (!sc) { showResults(); return; }
    sc.classList.add("active");
    decPanel.classList.add("visible");
    updateSidebar(n);
    renderStepDots(n);
    startTime = Date.now();
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  /* ══════════════════════════
     STEP DOTS in scenario header
  ══════════════════════════ */
  function renderStepDots(currentN) {
    const row = document.getElementById(`steps-row-${currentN}`);
    if (!row) return;
    row.innerHTML = "";
    for (let i = 1; i <= 10; i++) {
      const dot = document.createElement("div");
      dot.className = "scene-step-dot";
      if (results[i]) {
        dot.classList.add(results[i].ok ? "done" : "fail");
      } else if (i === currentN) {
        dot.classList.add("cur");
      }
      row.appendChild(dot);
    }
  }

  /* ══════════════════════════
     SIDEBAR
  ══════════════════════════ */
  function updateSidebar(active) {
    document.querySelectorAll(".sbi").forEach(el => {
      if (!el.classList.contains("done-ok") && !el.classList.contains("done-fail")) {
        el.classList.remove("active");
      }
    });
    const item = document.getElementById(`sbi-${active}`);
    if (item) item.classList.add("active");
    const progress = ((active - 1) / 10) * 100;
    if (progFill)     progFill.style.width = progress + "%";
    if (scoreCounter) scoreCounter.textContent = score;
    if (sidebarScore) sidebarScore.textContent = score;
  }

  function markSidebarDone(n, isOk, correctAnswer) {
    const item  = document.getElementById(`sbi-${n}`);
    const badge = document.getElementById(`rb-${n}`);
    const pip   = document.getElementById(`pip-${n}`);
    if (!item) return;
    item.classList.remove("active");
    item.classList.add(isOk ? "done-ok" : "done-fail");
    if (badge) badge.textContent = correctAnswer === "phishing" ? "Phishing" : "Legítimo";
    if (pip) {
      pip.style.background = isOk ? "#10b981" : "#ef4444";
      pip.style.boxShadow  = isOk ? "0 0 6px rgba(16,185,129,0.5)" : "0 0 6px rgba(239,68,68,0.5)";
    }
  }

  /* ══════════════════════════
     ANSWER BUTTONS
  ══════════════════════════ */
  document.querySelectorAll(".answer-btn").forEach(btn => {
    btn.addEventListener("click", (e) => {
      const answer  = e.currentTarget.getAttribute("data-answer");
      const scEl    = document.getElementById(`scenario-${step}`);
      if (!scEl) return;
      const correct  = scEl.getAttribute("data-correct-answer");
      const elapsed  = (Date.now() - startTime) / 1000;
      const isOk     = answer === correct;
      times.push({ step, elapsed });
      results[step] = { ok: isOk, correct };
      if (isOk) { score++; if (correct === "phishing") phishingOk++; else legitOk++; }
      markSidebarDone(step, isOk, correct);
      decPanel.classList.remove("visible");
      showFeedback(isOk, step, correct);
    });
  });

  /* ══════════════════════════
     KEYBOARD SHORTCUTS
  ══════════════════════════ */
  document.addEventListener("keydown", (e) => {
    if (!decPanel.classList.contains("visible")) return;
    if (e.key === "p" || e.key === "P") {
      document.querySelector('[data-answer="phishing"]')?.click();
    }
    if (e.key === "l" || e.key === "L") {
      document.querySelector('[data-answer="legitimo"]')?.click();
    }
  });

  /* ══════════════════════════
     FEEDBACK MODAL
  ══════════════════════════ */
  function showFeedback(isOk, n, correctAnswer) {
    const data   = FEEDBACKS[n];
    const icon   = document.getElementById("fb-icon");
    const title  = document.getElementById("fb-title");
    const typeEl = document.getElementById("fb-type");
    const header = document.getElementById("fb-header");
    const body   = document.getElementById("fb-body");
    const fbScoreEl = document.getElementById("fb-score");

    // Verdict header
    if (isOk) {
      icon.className   = "w-14 h-14 rounded-2xl flex items-center justify-center flex-shrink-0 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800/40";
      icon.innerHTML   = document.getElementById('tpl-accept').innerHTML;
      title.className  = "text-xl font-bold text-emerald-600 dark:text-emerald-400";
      title.textContent = "¡Análisis correcto!";
      header.className = "fb-verdict-ok flex items-center gap-4 p-5 border-b border-gray-200 dark:border-gray-800 rounded-t-2xl";
    } else {
      icon.className   = "w-14 h-14 rounded-2xl flex items-center justify-center flex-shrink-0 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/40";
      icon.innerHTML   = document.getElementById('tpl-x').innerHTML;
      title.className  = "text-xl font-bold text-red-600 dark:text-red-400";
      title.textContent = "¡Trampa detectada! Analicemos por qué";
      header.className = "fb-verdict-fail flex items-center gap-4 p-5 border-b border-gray-200 dark:border-gray-800 rounded-t-2xl";
    }
    typeEl.textContent  = data ? data.type : "";
    fbScoreEl.textContent = score;

    // Body HTML
    const sectionLabel = correctAnswer === "phishing"
      ? "Indicadores de Phishing en este mensaje"
      : "Por qué este mensaje es legítimo";
    let html = `<p class="fb-sec-title">${sectionLabel}</p>`;

    if (data?.indicators) {
      data.indicators.forEach(ind => {
        html += `
          <div class="fb-ind ${ind.c}">
            <div class="fb-ind-title">
              <span style="margin-top:1px;flex-shrink:0">${ind.c === "danger" ? "🔴" : "🟢"}</span>
              ${ind.t}
            </div>
            <div class="fb-ind-body">${ind.b}</div>
          </div>`;
      });
    }
    if (data?.lesson) html += `<div class="fb-lesson">${data.lesson}</div>`;

    const isLast = n === 10;
    html += `
      <button id="btn-next"
        class="w-full bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-bold py-3 rounded-xl transition-all text-[0.9rem] flex items-center justify-center gap-2">
        ${isLast ? "Ver mis resultados" : "Continuar al siguiente"}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </button>`;

    body.innerHTML = html;

    // Update sidebar counts
    if (scoreCounter) scoreCounter.textContent = score;
    if (sidebarScore) sidebarScore.textContent = score;
    if (progFill)     progFill.style.width = (step / 10 * 100) + "%";

    fbModal.classList.add("visible");
    document.getElementById("feedback-card").scrollTop = 0;

    document.getElementById("btn-next").addEventListener("click", () => {
      fbModal.classList.remove("visible");
      showScene(step + 1);
    });
  }

  /* ══════════════════════════
     RESULTS
  ══════════════════════════ */
  function showResults() {
    document.querySelectorAll(".scenario-container").forEach(el => el.classList.remove("active"));
    decPanel.classList.remove("visible");
    resultsScreen.classList.add("active");
    if (progFill)     progFill.style.width = "100%";
    if (scoreCounter) scoreCounter.textContent = "10";
    if (sidebarScore) sidebarScore.textContent = score;

    document.getElementById("display-name").textContent  = userName;
    document.getElementById("display-email").textContent = userEmail;

    // Score display
    const scoreEl = document.getElementById("final-score");
    scoreEl.textContent = score;
    // Color threshold
    const cls = score >= 9 ? "score-s" : score >= 7 ? "score-a" : score >= 5 ? "score-b" : "score-c";
    scoreEl.className = `text-5xl font-black ${cls} leading-none`;
    // Grade label
    const gradeEl = document.getElementById("score-grade");
    const grades = ["F","F","F","F","F","C","B","B","A","A","S"];
    const gradeColors = { S:"text-emerald-500", A:"text-blue-500", B:"text-amber-500", C:"text-orange-500", F:"text-red-500" };
    const g = grades[score];
    gradeEl.textContent = `Calificación: ${g}`;
    gradeEl.className = `text-xs font-bold mt-0.5 ${gradeColors[g]}`;

    // Animate ring
    setTimeout(() => {
      const arc = document.getElementById("score-arc");
      if (arc) {
        const circumference = 314;
        const offset = circumference - (score / 10) * circumference;
        arc.style.strokeDashoffset = offset;
      }
    }, 200);

    document.getElementById("phishing-correct").textContent = phishingOk + " / 8";
    document.getElementById("legit-correct").textContent    = legitOk + " / 2";

    let total = 0, maxT = 0, longestN = 1;
    times.forEach(d => {
      total += d.elapsed;
      if (d.elapsed > maxT) { maxT = d.elapsed; longestN = d.step; }
    });
    document.getElementById("total-time").textContent      = total.toFixed(1) + " seg";
    document.getElementById("longest-scenario").textContent = `Esc. ${String(longestN).padStart(2,'0')} (${maxT.toFixed(1)}s)`;
    window.scrollTo({ top: 0, behavior: "smooth" });

    // Build per-scene times map and dispatch to Firebase module
    const scenesTimes = {};
    times.forEach(d => { scenesTimes[String(d.step)] = parseFloat(d.elapsed.toFixed(2)); });

    window.__quizEmail = userEmail;
    window.dispatchEvent(new CustomEvent('quiz:completed', {
      detail: {
        nombre:       userName,
        email:        userEmail,
        score:        score,
        totalTime:    parseFloat(total.toFixed(2)),
        phishingOk:   phishingOk,
        legitOk:      legitOk,
        longestScene: longestN,
        longestTime:  parseFloat(maxT.toFixed(2)),
        scenesTimes:  scenesTimes,
      }
    }));
  }

});
</script>

<!-- ████ FIREBASE — RANKING GLOBAL ████ -->
<script type="module" is:inline>
import { initializeApp }       from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
import { getFirestore, doc, setDoc, collection, query,
         orderBy, limit, onSnapshot, serverTimestamp }
  from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

/* ── Inicializar Firebase ── */
const firebaseConfig = {
  apiKey:            "AIzaSyAzBrFQKLRZZXEmJ5tIUkoavsSKr3GWBUY",
  authDomain:        "phishing-quiz-cno.firebaseapp.com",
  projectId:         "phishing-quiz-cno",
  storageBucket:     "phishing-quiz-cno.firebasestorage.app",
  messagingSenderId: "165839107448",
  appId:             "1:165839107448:web:57dab96654dbcf5f7b848d"
};
const app = initializeApp(firebaseConfig);
const db  = getFirestore(app);

/* ── Escuchar evento del quiz ── */
window.addEventListener('quiz:completed', async (e) => {
  const data = e.detail;

  // Usar email sanitizado como ID del documento → actualiza si ya existe
  const docId = data.email.toLowerCase().replace(/[^a-z0-9]/g, '_');

  try {
    await setDoc(doc(db, 'results', docId), {
      nombre:       data.nombre,
      email:        data.email,
      score:        data.score,
      totalTime:    data.totalTime,
      phishingOk:   data.phishingOk,
      legitOk:      data.legitOk,
      longestScene: data.longestScene,
      longestTime:  data.longestTime,
      scenesTimes:  data.scenesTimes,
      completedAt:  serverTimestamp(),
    });
  } catch (err) {
    console.error('[Firebase] Error al guardar:', err);
    const errEl = document.getElementById('ranking-error');
    const loadEl = document.getElementById('ranking-loading');
    if (errEl)  errEl.classList.remove('hidden');
    if (loadEl) loadEl.classList.add('hidden');
    return;
  }

  startRankingListener();
});

/* ── Listener en tiempo real ── */
function startRankingListener() {
  const q = query(
    collection(db, 'results'),
    orderBy('score', 'desc'),
    limit(50)
  );

  onSnapshot(q, (snap) => {
    const docs = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    renderRanking(docs);
    renderAnalysis(docs);
  }, (err) => {
    console.error('[Firebase] Error en listener:', err);
    const errEl  = document.getElementById('ranking-error');
    const loadEl = document.getElementById('ranking-loading');
    if (errEl)  errEl.classList.remove('hidden');
    if (loadEl) loadEl.classList.add('hidden');
  });
}

/* ── Renderizar tabla de ranking ── */
function renderRanking(docs) {
  const loadEl    = document.getElementById('ranking-loading');
  const tableWrap = document.getElementById('ranking-table-wrap');
  const tbody     = document.getElementById('ranking-body');
  const capCount  = document.getElementById('ranking-cap-count');
  if (!tbody) return;

  if (loadEl)    loadEl.classList.add('hidden');
  if (tableWrap) tableWrap.classList.remove('hidden');
  if (capCount)  capCount.textContent = `${docs.length} entrada${docs.length !== 1 ? 's' : ''}`;

  const currentEmail = (window.__quizEmail || '').toLowerCase();

  tbody.innerHTML = docs.map((row, i) => {
    const pos     = i + 1;
    const isMe    = row.email?.toLowerCase() === currentEmail;
    const medal   = pos === 1 ? '🥇' : pos === 2 ? '🥈' : pos === 3 ? '🥉' : `#${pos}`;
    const posClass = pos === 1 ? 'gold' : pos === 2 ? 'silver' : pos === 3 ? 'bronze' : '';
    const sClass  = row.score >= 9 ? 'score-col-s'
                  : row.score >= 7 ? 'score-col-a'
                  : row.score >= 5 ? 'score-col-b'
                  :                  'score-col-c';
    const tiempo  = typeof row.totalTime === 'number' ? row.totalTime.toFixed(1) + 's' : '—';
    // Show first name + first letter of last name for privacy
    const partes  = (row.nombre || 'Anónimo').trim().split(' ');
    const display = partes.length >= 2
      ? `${partes[0]} ${partes[1][0]}.`
      : partes[0];

    return `<tr class="${isMe ? 'ranking-row-me' : ''}">
      <td><span class="ranking-pos ${posClass}">${medal}</span></td>
      <td class="font-semibold ${isMe ? 'text-blue-300' : 'text-slate-400'}">
        ${display}${isMe ? ' <span style="font-size:0.6rem;color:#3b82f6;font-family:monospace;font-weight:700;margin-left:4px;background:rgba(59,130,246,0.1);padding:0.1rem 0.3rem;border-radius:0.2rem;border:1px solid rgba(59,130,246,0.2);">TÚ</span>' : ''}
      </td>
      <td class="text-center"><span class="ranking-score ${sClass}">${row.score}/10</span></td>
      <td class="text-center hidden md:table-cell" style="color:#334155;font-family:monospace;font-size:0.75rem;">${tiempo}</td>
      <td class="text-center hidden md:table-cell" style="color:#334155;font-size:0.75rem;">${row.phishingOk ?? '—'}/8</td>
      <td class="text-center hidden md:table-cell" style="color:#334155;font-size:0.75rem;">${row.legitOk ?? '—'}/2</td>
    </tr>`;
  }).join('');
}

/* ── Renderizar análisis de grupo ── */
function renderAnalysis(docs) {
  const wrap     = document.getElementById('ranking-analysis');
  const cardsEl  = document.getElementById('analysis-cards');
  const barsEl   = document.getElementById('detection-bars');
  if (!wrap || !cardsEl || !barsEl || docs.length === 0) return;

  wrap.classList.remove('hidden');

  const n        = docs.length;
  const avgScore = (docs.reduce((s, d) => s + (d.score    || 0), 0) / n).toFixed(1);
  const avgTime  = (docs.reduce((s, d) => s + (d.totalTime || 0), 0) / n).toFixed(1);

  // Best score
  const best = docs[0]; // already sorted desc by score

  // Per-scene average times
  const sceneTotals = {};
  docs.forEach(d => {
    if (d.scenesTimes && typeof d.scenesTimes === 'object') {
      Object.entries(d.scenesTimes).forEach(([sc, t]) => {
        if (!sceneTotals[sc]) sceneTotals[sc] = { total: 0, count: 0 };
        sceneTotals[sc].total += Number(t);
        sceneTotals[sc].count++;
      });
    }
  });

  // Slowest scenario on average
  let slowestSc = '—', slowestAvg = 0;
  Object.entries(sceneTotals).forEach(([sc, v]) => {
    const avg = v.total / v.count;
    if (avg > slowestAvg) { slowestAvg = avg; slowestSc = sc; }
  });
  const slowestLabel = slowestSc !== '—'
    ? `Esc. ${String(slowestSc).padStart(2,'0')}`
    : '—';

  // Participant of the moment (highest score, lowest time)
  const bestName = (best.nombre || 'Anónimo').trim().split(' ')[0];

  cardsEl.innerHTML = `
    <div class="analysis-card">
      <p class="analysis-lbl">Participantes</p>
      <p class="analysis-val">${n}</p>
      <p class="analysis-sub">han completado el quiz</p>
    </div>
    <div class="analysis-card">
      <p class="analysis-lbl">Score promedio</p>
      <p class="analysis-val">${avgScore}<span style="color:#1e293b;font-size:0.8rem;font-weight:500">/10</span></p>
    </div>
    <div class="analysis-card">
      <p class="analysis-lbl">Tiempo promedio</p>
      <p class="analysis-val">${avgTime}<span style="color:#1e293b;font-size:0.8rem;font-weight:500">s</span></p>
    </div>
    <div class="analysis-card">
      <p class="analysis-lbl">Escenario más lento</p>
      <p class="analysis-val">${slowestLabel}</p>
      <p class="analysis-sub">${slowestAvg.toFixed(1)}s prom. grupal</p>
    </div>
    <div class="analysis-card">
      <p class="analysis-lbl">Mejor puntaje</p>
      <p class="analysis-val">${best.score}/10</p>
      <p class="analysis-sub">${bestName}</p>
    </div>`;

  // Bars: time per scenario
  if (Object.keys(sceneTotals).length > 0) {
    const avgs = Object.entries(sceneTotals)
      .map(([sc, v]) => ({ sc: String(sc), avg: v.total / v.count }))
      .sort((a, b) => parseInt(a.sc) - parseInt(b.sc));

    const maxAvg = Math.max(...avgs.map(x => x.avg));

    barsEl.innerHTML = avgs.map(({ sc, avg }) => {
      const pct   = Math.min(100, Math.round((avg / maxAvg) * 100));
      // Gradient based on intensity
      const barColor = pct > 75
        ? 'linear-gradient(90deg, #b91c1c, #ef4444)'
        : pct > 50
        ? 'linear-gradient(90deg, #b45309, #f59e0b)'
        : 'linear-gradient(90deg, #1d4ed8, #3b82f6)';
      return `
        <div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.2rem;">
            <span style="font-size:0.7rem;color:#334155;font-family:'Courier New',monospace;font-weight:700;">ESC ${sc.padStart(2,'0')}</span>
            <span style="font-size:0.68rem;color:#1e293b;font-family:'Courier New',monospace;">${avg.toFixed(1)}s</span>
          </div>
          <div class="det-bar-wrap">
            <div class="det-bar" style="width:${pct}%;background:${barColor}"></div>
          </div>
        </div>`;
    }).join('');
  } else {
    barsEl.innerHTML = '<p style="font-size:0.75rem;color:#1e293b;">No hay datos suficientes aún.</p>';
  }
}
</script>
</Layout>