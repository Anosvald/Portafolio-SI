{/* ================================================================ */}
{/* ESTILOS GLOBALES HACKER                                          */}
{/* ================================================================ */}
<style is:global>
  /* ---- MATRIX CANVAS ---- */
  #matrix-canvas {
    image-rendering: pixelated;
  }

  /* ---- SCANLINES CRT ---- */
  #scanlines {
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 65, 0.03) 2px,
      rgba(0, 255, 65, 0.03) 4px
    );
    pointer-events: none;
  }

  /* ---- GLITCH EN TÍTULOS ---- */
  .glitch-title {
    position: relative;
    display: inline-block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .glitch-title:hover::before,
    .glitch-title:hover::after {
      content: attr(data-text);
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }

    .glitch-title:hover::before {
      color: #00ff41;
      animation: glitch-1 0.3s infinite linear;
      clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
      opacity: 0.7;
    }

    .glitch-title:hover::after {
      color: #ff003c;
      animation: glitch-2 0.3s infinite linear;
      clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
      opacity: 0.7;
    }
  }

  @keyframes glitch-1 {
    0%   { transform: translate(0); }
    20%  { transform: translate(-2px, 1px); }
    40%  { transform: translate(2px, -1px); }
    60%  { transform: translate(-1px, 2px); }
    80%  { transform: translate(1px, -2px); }
    100% { transform: translate(0); }
  }

  @keyframes glitch-2 {
    0%   { transform: translate(0); }
    20%  { transform: translate(2px, -1px); }
    40%  { transform: translate(-2px, 1px); }
    60%  { transform: translate(1px, -2px); }
    80%  { transform: translate(-1px, 2px); }
    100% { transform: translate(0); }
  }

  /* ---- CURSOR PARPADEANTE ---- */
  .terminal-cursor {
    display: inline-block;
    animation: blink 1s step-end infinite;
    color: #00ff41;
    font-weight: bold;
  }

  .terminal-cursor--red {
    color: #ff003c;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ---- TERMINAL MEJORADA ---- */
  .terminal-waiting {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1rem 2rem;
    border: 1px dashed rgba(0, 255, 65, 0.25);
    border-radius: 0.75rem;
    background-color: #0d1117;
    position: relative;
    overflow: hidden;
  }

  .dark .terminal-waiting {
    border-color: rgba(0, 255, 65, 0.2);
  }

  .terminal-waiting--locked {
    border-color: rgba(255, 0, 60, 0.2) !important;
    background-color: #100808 !important;
  }

  /* Línea superior neón */
  .terminal-waiting::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 65, 0.6), transparent);
  }

  .terminal-waiting--locked::before {
    background: linear-gradient(90deg, transparent, rgba(255, 0, 60, 0.5), transparent) !important;
  }

  /* Scan line animado que cruza la terminal */
  .terminal-scanline {
    position: absolute;
    top: -100%;
    left: 0;
    right: 0;
    height: 40px;
    background: linear-gradient(transparent, rgba(0, 255, 65, 0.04), transparent);
    animation: scan 4s linear infinite;
    pointer-events: none;
  }

  @keyframes scan {
    0%   { top: -10%; }
    100% { top: 110%; }
  }

  /* Barra superior de terminal (dots rojo/amarillo/verde) */
  .terminal-top-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid rgba(0, 255, 65, 0.08);
    margin-bottom: 1rem;
  }

  /* Ajuste de padding interno por la top-bar */
  .terminal-waiting > *:not(.terminal-top-bar):not(.terminal-scanline) {
    margin-top: 0.5rem;
  }

  /* ---- HACKER DETAILS — borde con glow sutil ---- */
  .dark .hacker-details {
    transition: box-shadow 0.3s ease;
  }

  .dark .hacker-details:hover {
    box-shadow: 0 0 20px -4px rgba(0, 255, 65, 0.08), 0 0 0 1px rgba(0, 255, 65, 0.1);
  }

  .dark .hacker-details--locked:hover {
    box-shadow: 0 0 20px -4px rgba(255, 0, 60, 0.08), 0 0 0 1px rgba(255, 0, 60, 0.1);
  }

  /* ---- ICONO CANDADO — animación shake ---- */
  .lock-icon {
    animation: lock-shake 5s ease-in-out infinite;
  }

  @keyframes lock-shake {
    0%, 90%, 100% { transform: rotate(0deg); }
    92%            { transform: rotate(-5deg); }
    94%            { transform: rotate(5deg); }
    96%            { transform: rotate(-3deg); }
    98%            { transform: rotate(3deg); }
  }
</style>

{/* ================================================================ */}
{/* SCRIPTS: MATRIX RAIN + HUD CLOCK + PACKETS COUNTER              */}
{/* ================================================================ */}
<script>
  /* ---- MATRIX RAIN ---- */
  (function initMatrix() {
    const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789<>{}[]|/\\#@$%^&*~'.split('');
    const fontSize = 14;
    let columns: number[] = [];
    let drops: number[] = [];

    function resize() {
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
      columns = Array(Math.floor(canvas.width / fontSize)).fill(0);
      drops   = columns.map(() => Math.random() * -canvas.height);
    }

    resize();
    window.addEventListener('resize', resize);

    function draw() {
      if (!ctx) return;
      ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = `${fontSize}px monospace`;

      drops.forEach((y, i) => {
        const char = chars[Math.floor(Math.random() * chars.length)];
        const x    = i * fontSize;

        // Carácter principal: blanco/verde brillante
        const ratio = y / canvas.height;
        if (ratio > 0.8) {
          ctx.fillStyle = '#ffffff';
        } else {
          ctx.fillStyle = `rgba(0, 255, 65, ${0.3 + ratio * 0.5})`;
        }

        if (y > 0) ctx.fillText(char, x, y);

        drops[i] += fontSize;
        if (drops[i] > canvas.height + fontSize * 5) {
          drops[i] = Math.random() * -canvas.height * 0.5;
        }
      });
    }

    setInterval(draw, 50);
  })();

  /* ---- HUD RELOJ ---- */
  (function initClock() {
    const el = document.getElementById('hud-time');
    if (!el) return;

  function tick() {
    if (!el) return;   // ← guard: si es null, no hace nada
    const now = new Date();
    const h   = String(now.getHours()).padStart(2, '0');
    const m   = String(now.getMinutes()).padStart(2, '0');
    const s   = String(now.getSeconds()).padStart(2, '0');
    el.textContent = `${h}:${m}:${s}`;
  }

    tick();
    setInterval(tick, 1000);
  })();

  /* ---- HUD PACKETS COUNTER (fake, estético) ---- */
  (function initPackets() {
    const el = document.getElementById('hud-packets');
    if (!el) return;

    let count = Math.floor(Math.random() * 99999);

    setInterval(() => {
      count += Math.floor(Math.random() * 50) + 1;
      el.textContent = `PKT: ${String(count).padStart(6, '0')}`;
    }, 200);
  })();
</script>