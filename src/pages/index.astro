---
import Layout from "../layouts/Layout.astro" 

import AboutMe from "../components/AboutMe.astro"
import Information from "../components/Informacion.astro" 
import Briefcase from "../components/Icons/Briefcase.astro"
import Certificate from "../components/Icons/Certificate.astro"
import CodeIcon from "../components/Icons/Code.astro"
import CodeIcon1 from "../components/Icons/codee.astro"
import Experience from "../components/Experience.astro"
import ProfileCheck from "../components/Icons/ProfileCheck.astro"
import Projects from "../components/Projects.astro"
import SectionContainer from "../components/SectionContainer.astro"
import Hero from "../components/Hero.astro"
import TitleSection from "../components/TitleSection.astro"
import Awards from "../components/Awards.astro" 
import Bulb from "../components/Icons/Bulb.astro"
import Contacto from '../components/Contacto.astro'
import Create from '../components/Create.astro'
import Tareas from "../components/Tareas.astro"
import School from "../components/Icons/Tareas.astro"
---

<Layout
  title="Portafolio de Osvaldo"
  description="Portafolio profesional de Diego Osvaldo Hernández Fernández, estudiante de Ingeniería en TI enfocado en ciberseguridad, pentesting y respuesta a incidentes."
>
  <main class="px-4">
    <SectionContainer class="py-16 md:py-36">
      <Hero>
        </slot>
      </Hero>
    </SectionContainer>
    
    <div class="space-y-24">

      <SectionContainer id="information">
        <TitleSection>
          <Bulb class="size-7" />
          Presentación del portafolio
        </TitleSection>
        <Information />
      </SectionContainer>  

      <SectionContainer id="sobre-mi">
        <TitleSection>
          <ProfileCheck class="size-8" />
          Sobre mí
        </TitleSection>
        <AboutMe />
      </SectionContainer>

      {/* --- SECCIÓN DE PROYECTOS DESPLEGABLE --- */}
      <SectionContainer id="proyectos">
        <TitleSection>
          <CodeIcon class="size-7" />
          Proyectos
        </TitleSection>
        
        <div class="flex flex-col gap-6 mt-8">
          
          {/* PROYECTOS PARCIAL 1 (Abierto por defecto con la etiqueta 'open') */}
          <details class="group border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden shadow-sm bg-white dark:bg-gray-900/20" open>
            <summary class="flex items-center justify-between cursor-pointer p-6 bg-gray-50 dark:bg-gray-800/50 hover:bg-gray-100 dark:hover:bg-gray-800/80 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <h3 class="text-2xl font-bold text-blue-500/90">Parcial 1</h3>
              <span class="transition-transform duration-300 group-open:-rotate-180">
                <svg class="size-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>
            <div class="p-6 md:p-8 pt-0 md:pt-0">
              <Projects />
            </div>
          </details>

          {/* PROYECTOS PARCIAL 2 */}
          <details class="group border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden shadow-sm bg-white dark:bg-gray-900/20">
            <summary class="flex items-center justify-between cursor-pointer p-6 bg-gray-50 dark:bg-gray-800/50 hover:bg-gray-100 dark:hover:bg-gray-800/80 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <h3 class="text-2xl font-bold text-gray-500 dark:text-gray-400">Parcial 2</h3>
              <span class="transition-transform duration-300 group-open:-rotate-180">
                <svg class="size-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>
            <div class="p-6">
              {/* DISEÑO CIBERSEGURIDAD EN ESPERA */}
              <div class="flex flex-col items-center justify-center py-12 px-4 border border-dashed border-gray-300 dark:border-green-500/30 rounded-xl bg-gray-50 dark:bg-[#0d1117] relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-green-500/50 to-transparent"></div>
                <CodeIcon class="size-10 text-gray-400 dark:text-green-500/50 mb-3" />
                <p class="text-lg text-gray-600 dark:text-green-400 font-mono text-center">
                  root@osvaldo-pc:~# esperando_proyectos...
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-600 font-mono text-center mt-2 animate-pulse">
                  [ ACCESO RESTRINGIDO - ESPERANDO INSTRUCCIONES ]
                </p>
              </div>
            </div>
          </details>

          {/* PROYECTOS PARCIAL 3 */}
          <details class="group border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden shadow-sm bg-white dark:bg-gray-900/20">
            <summary class="flex items-center justify-between cursor-pointer p-6 bg-gray-50 dark:bg-gray-800/50 hover:bg-gray-100 dark:hover:bg-gray-800/80 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <h3 class="text-2xl font-bold text-gray-500 dark:text-gray-400">Parcial 3</h3>
              <span class="transition-transform duration-300 group-open:-rotate-180">
                <svg class="size-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>
            <div class="p-6">
              <div class="flex flex-col items-center justify-center py-12 px-4 border border-dashed border-gray-300 dark:border-green-500/30 rounded-xl bg-gray-50 dark:bg-[#0d1117] relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-green-500/50 to-transparent"></div>
                <CodeIcon class="size-10 text-gray-400 dark:text-green-500/50 mb-3" />
                <p class="text-lg text-gray-600 dark:text-green-400 font-mono text-center">
                  root@osvaldo-pc:~# esperando_proyectos...
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-600 font-mono text-center mt-2 animate-pulse">
                  [ ESTADO: BLOQUEADO HASTA NUEVO AVISO ]
                </p>
              </div>
            </div>
          </details>

        </div>
      </SectionContainer>

      {/* --- SECCIÓN DE TAREAS DESPLEGABLE --- */}
      <SectionContainer id="tareas">
        <TitleSection>
          <School class="size-7" />
          Tareas y Actividades
        </TitleSection>

        <div class="flex flex-col gap-6 mt-8">
          
          {/* TAREAS PARCIAL 1 */}
          <details class="group border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden shadow-sm bg-white dark:bg-gray-900/20" open>
            <summary class="flex items-center justify-between cursor-pointer p-6 bg-gray-50 dark:bg-gray-800/50 hover:bg-gray-100 dark:hover:bg-gray-800/80 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <h3 class="text-2xl font-bold text-blue-500/90">Parcial 1</h3>
              <span class="transition-transform duration-300 group-open:-rotate-180">
                <svg class="size-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>
            <div class="p-6 md:p-8 pt-0 md:pt-0">
              <Tareas />
            </div>
          </details>

          {/* TAREAS PARCIAL 2 */}
          <details class="group border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden shadow-sm bg-white dark:bg-gray-900/20">
            <summary class="flex items-center justify-between cursor-pointer p-6 bg-gray-50 dark:bg-gray-800/50 hover:bg-gray-100 dark:hover:bg-gray-800/80 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <h3 class="text-2xl font-bold text-gray-500 dark:text-gray-400">Parcial 2</h3>
              <span class="transition-transform duration-300 group-open:-rotate-180">
                <svg class="size-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>
            <div class="p-6">
              <div class="flex flex-col items-center justify-center py-12 px-4 border border-dashed border-gray-300 dark:border-green-500/30 rounded-xl bg-gray-50 dark:bg-[#0d1117] relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-green-500/50 to-transparent"></div>
                <CodeIcon class="size-10 text-gray-400 dark:text-green-500/50 mb-3" />
                <p class="text-lg text-gray-600 dark:text-green-400 font-mono text-center">
                  >_ Escaneando nuevas vulnerabilidades...
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-600 font-mono text-center mt-2 animate-pulse">
                  [ LAS TAREAS SE DESENCRIPTARÁN PRONTO ]
                </p>
              </div>
            </div>
          </details>

          {/* TAREAS PARCIAL 3 */}
          <details class="group border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden shadow-sm bg-white dark:bg-gray-900/20">
            <summary class="flex items-center justify-between cursor-pointer p-6 bg-gray-50 dark:bg-gray-800/50 hover:bg-gray-100 dark:hover:bg-gray-800/80 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <h3 class="text-2xl font-bold text-gray-500 dark:text-gray-400">Parcial 3</h3>
              <span class="transition-transform duration-300 group-open:-rotate-180">
                <svg class="size-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </span>
            </summary>
            <div class="p-6">
              <div class="flex flex-col items-center justify-center py-12 px-4 border border-dashed border-gray-300 dark:border-green-500/30 rounded-xl bg-gray-50 dark:bg-[#0d1117] relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-green-500/50 to-transparent"></div>
                <CodeIcon class="size-10 text-gray-400 dark:text-green-500/50 mb-3" />
                <p class="text-lg text-gray-600 dark:text-green-400 font-mono text-center">
                  >_ Sistema inactivo...
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-600 font-mono text-center mt-2 animate-pulse">
                  [ ESPERANDO CARGA ÚTIL DEL PROFESOR ]
                </p>
              </div>
            </div>
          </details>

        </div>
      </SectionContainer>

      <SectionContainer id="create">
        <TitleSection>
          <CodeIcon1 class="size-7" />
          Información técnica básica
        </TitleSection>
        <Create />
      </SectionContainer>

      <SectionContainer id="contacto">
        <Contacto />
      </SectionContainer>

    </div>
  </main>
</Layout>