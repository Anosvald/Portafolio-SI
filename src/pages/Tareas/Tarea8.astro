  <!-- ══════════════════════════════════════
       SCRIPT: scroll suave + progreso
  ══════════════════════════════════════ -->
  <script>
    // Scroll suave al lab cuando se hace clic en el roadmap
    function scrollToLab(id: number) {
      const el = document.getElementById("lab-" + id);
      if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
    }
    (window as any).scrollToLab = scrollToLab;

    const TOTAL = 18;
    const seen = new Set<number>();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const rawId = (entry.target as HTMLElement).id.replace("lab-", "");
          const id = parseInt(rawId, 10);
          if (!id) return;

          // Marcar como visitado cuando sea suficientemente visible
          if (entry.isIntersecting && entry.intersectionRatio >= 0.15) {
            seen.add(id);
          }

          // Resaltar el item activo en el roadmap
          document.querySelectorAll<HTMLElement>(".roadmap-item").forEach(item => {
            item.classList.remove("active");
          });
          if (entry.isIntersecting) {
            const activeItem = document.querySelector<HTMLElement>(
              `.roadmap-item[data-lab-id="${id}"]`
            );
            if (activeItem) {
              activeItem.classList.add("active");
              const sidebar = document.getElementById("roadmap-sidebar");
              if (sidebar) {
                sidebar.scrollTo({ top: activeItem.offsetTop - 120, behavior: "smooth" });
              }
            }
          }

          // Actualizar contador y barra de progreso
          const countEl = document.getElementById("roadmap-count");
          const barEl   = document.getElementById("roadmap-progress-bar");
          if (countEl) countEl.textContent = String(seen.size);
          if (barEl)   barEl.style.width   = (seen.size / TOTAL * 100) + "%";
        });
      },
      { threshold: [0.15], rootMargin: "-10% 0px -10% 0px" }
    );

    // Observar cada card de laboratorio
    document.querySelectorAll<HTMLElement>("[id^='lab-']").forEach(el => {
      observer.observe(el);
    });
  </script>

