// --- GRUPOS DEL ROADMAP ---
const ROADMAP_GRUPOS = [
  { label: "In-band", color: "green",  ids: [1, 2] },
  { label: "UNION",   color: "blue",   ids: [3, 4, 5, 6, 7, 8, 9, 10] },
  { label: "Blind",   color: "yellow", ids: [11, 12, 13, 14, 15] },
  { label: "OOB",     color: "purple", ids: [16, 17] },
  { label: "WAF",     color: "red",    ids: [18] },
];

// --- TODA LA LÓGICA DEL ROADMAP SE PROCESA AQUÍ EN EL FRONTMATTER ---
// Mapas de color (objetos planos, sin TypeScript genéricos)
const COLOR_DOT = {
  green:  "bg-green-500",
  blue:   "bg-blue-500",
  yellow: "bg-yellow-400",
  purple: "bg-purple-500",
  red:    "bg-red-500",
};

const COLOR_LABEL = {
  green:  "text-green-400 bg-green-900/20",
  blue:   "text-blue-400 bg-blue-900/20",
  yellow: "text-yellow-400 bg-yellow-900/20",
  purple: "text-purple-400 bg-purple-900/20",
  red:    "text-red-400 bg-red-900/20",
};

// Pre-procesamos cada lab con todos los valores que necesita el template
const LABS_CON_GRUPO = LABS.map((lab, i) => {
  const group = ROADMAP_GRUPOS.find(g => g.ids.includes(lab.id)) ?? ROADMAP_GRUPOS[0];
const dotColor   = COLOR_DOT[group.color as keyof typeof COLOR_DOT]   ?? "bg-blue-500";
 const labelColor = COLOR_LABEL[group.color as keyof typeof COLOR_LABEL] ?? "";
  const nombreCorto = lab.nombre.length > 48
    ? lab.nombre.substring(0, 46) + "…"
    : lab.nombre;

  return {
    ...lab,
    isLast:       i === LABS.length - 1,
    isGroupStart: group.ids[0] === lab.id,
    groupLabel:   group.label,
    dotColor,
    labelColor,
    nombreCorto,
  };
});
